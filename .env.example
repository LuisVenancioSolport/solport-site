# Copie este arquivo para .env.local e preencha com as credenciais reais.
# Enquanto essas variáveis não existirem, o site funciona normalmente:
# os formulários respondem com sucesso e o lead é apenas logado no console
# do servidor (não é perdido, mas também não é persistido).

# Supabase — banco de leads (RPD Seção 11). Use a service_role key
# (não a anon key): ela roda só no servidor (API route) e é a única
# autorizada a gravar na tabela `leads`, que tem RLS habilitado sem
# policy para anon/authenticated. Painel: Project Settings > API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — notificação por e-mail a cada novo lead (RPD Seção 11).
# Painel: resend.com/api-keys. Enquanto o domínio de envio não estiver
# verificado no Resend, use o remetente padrão onboarding@resend.dev.
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=contato@solport.com.br

# Google Analytics 4 (RPD Seção 4.3/9.3). ID de measurement, ex.: G-XXXXXXX.
NEXT_PUBLIC_GA_ID=

# Meta Pixel (RPD Seção 4.3/9.3). ID numérico do pixel.
NEXT_PUBLIC_META_PIXEL_ID=
